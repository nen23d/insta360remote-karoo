<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del campo gráfico táctil para el perfil de ride del Karoo.

    Estructura:
    ┌─────────────────────────────────┐
    │  ● REC          [estado grande] │
    │  78%            [batería chico] │
    └─────────────────────────────────┘

    El fondo cambia de color:
      - Grabando    → rojo oscuro  #3A0000
      - Listo       → verde oscuro #003A1A
      - Sin cámara  → gris oscuro  #1A1A1A

    El layout raíz (root_layout) recibe el setOnClickPendingIntent
    para que cualquier toque en el campo dispare start/stop.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="6dp"
    android:background="#1A1A1A">

    <!-- Texto principal: "● REC" / "◉ LISTO" / "✕ SIN CAM" -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="◉ LISTO"
        android:textColor="#00FF88"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:gravity="center" />

    <!-- Batería: "78%" -->
    <TextView
        android:id="@+id/tv_battery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="--"
        android:textColor="#888888"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:gravity="center" />

</LinearLayout>
